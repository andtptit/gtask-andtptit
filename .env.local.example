# Copy thành .env.local và điền từ Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Service role key — dùng cho tính năng admin tạo thành viên.
# TUYỆT ĐỐI không để lộ ra client / commit lên git. Trên Vercel thêm vào Environment Variables.
SUPABASE_SERVICE_ROLE_KEY=eyJ...
